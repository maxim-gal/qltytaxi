<%- include('../partials/head') %>

<section class="features py-5">
  <div class="container">
    <div class="row justify-content-center">
      <div class="col-lg-8">
        <div class="p-4 rounded-4" style="background: #1A1A1A; border: 1px solid #333;">
          <h1 class="text-warning mb-4"><%= taxi.name %></h1>

          <dl class="row mb-4">
            <dt class="col-sm-3 text-secondary">Подача:</dt>
            <dd class="col-sm-9"><%= taxi.podacha || '—' %></dd>

            <dt class="col-sm-3 text-secondary">Стоимость:</dt>
            <dd class="col-sm-9"><%= taxi.cost || '—' %></dd>

            <dt class="col-sm-3 text-secondary">Класс:</dt>
            <dd class="col-sm-9"><%= taxi.class || '—' %></dd>

            <% if (taxi.phone) { %>
            <dt class="col-sm-3 text-secondary">Телефон:</dt>
            <dd class="col-sm-9">
              <a href="tel:<%= taxi.phone.replace(/[^+\d]/g, '') %>" class="text-warning"><%= taxi.phone %></a>
            </dd>
            <% } %>
          </dl>

          <% if (taxi.description) { %>
            <h5 class="text-warning">Описание автопарка</h5>
            <p><%= taxi.description %></p>
          <% } %>

          <% if (taxi.contacts) { %>
            <h5 class="text-warning">Контакты</h5>
            <p><%= taxi.contacts %></p>
          <% } %>

          <% if (taxi.phone) { %>
            <a href="tel:<%= taxi.phone.replace(/[^+\d]/g, '') %>" class="btn btn-warning rounded-pill px-4 mt-3">
              <i class="fas fa-phone-alt me-2"></i> Позвонить
            </a>
          <% } %>

          <div class="mt-4">
            <a href="/" class="btn btn-outline-light"><i class="fas fa-arrow-left me-2"></i>На главную</a>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<%- include('../partials/footer') %>