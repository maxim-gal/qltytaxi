<%- include('../partials/head') %>

<section class="features py-5">
  <div class="container">
    <div class="row align-items-center g-5">
      <% if (article.image_url) { %>
        <div class="col-md-6">
          <img src="<%= article.image_url %>" class="img-fluid rounded-4" alt="<%= article.title %>">
        </div>
      <% } %>
      <div class="<%= article.image_url ? 'col-md-6' : 'col-12' %>">
        <h1 class="text-warning mb-4"><%= article.title %></h1>
        <div class="article-text">
          <%- article.content %>
        </div>
        <a href="/articles" class="btn btn-outline-warning mt-4">
          <i class="fas fa-arrow-left me-2"></i>Все статьи
        </a>
      </div>
    </div>
  </div>
</section>

<%- include('../partials/footer') %>